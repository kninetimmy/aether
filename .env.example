# aether configuration — copy to `.env` (run.sh does this for you on first run).
#
# `.env` is gitignored and machine-local: it holds YOUR station coordinates, API
# keys, and toggles (PRD §5 — coordinates and secrets are never committed). run.sh
# sources this file before launching, so anything set here becomes an AETHER_* env
# var for the backend. Everything is OFF by default except the demo source, so a
# fresh clone shows a populated map with zero setup; turn real sources on below.
#
# Leave a line commented (or unset) to keep aether's built-in default.

# ── Demo / no-hardware ────────────────────────────────────────────────────────
# 1 = publish simulated mixed records so the map is populated with no radios/keys.
# Set 0 once you have real sources configured below.
AETHER_DEMO_SOURCE=1

# ── Station (your location; drives the AOI + distance/geofence alerts) ─────────
# Decimal degrees. Required for the distance-based alert templates to evaluate.
#AETHER_STATION_LAT=40.0
#AETHER_STATION_LON=-95.0
#AETHER_STATION_RADIUS_NM=500

# ── Local bus (Mosquitto) ─────────────────────────────────────────────────────
# run.sh starts a loopback broker for you; override only if you run your own.
#AETHER_MQTT_HOST=127.0.0.1
#AETHER_MQTT_PORT=1883

# ── Local SDR adapters (need the radios + decoders running) ────────────────────
#AETHER_LOCAL_ADSB=1          # readsb aircraft.json adapter
#AETHER_LOCAL_APRS=1          # Dire Wolf KISS APRS adapter (receive-only)

# ── Network feeds (no key needed) ─────────────────────────────────────────────
#AETHER_NETWORK_ADSB=1        # network ADS-B (adsb.fi) over the AOI
#AETHER_APRS_IS=1             # APRS-IS display feed
#AETHER_USGS=1                # USGS earthquakes (GeoJSON)
#AETHER_SONDEHUB=1            # SondeHub radiosonde telemetry

# ── Feeds that need an API key ────────────────────────────────────────────────
# AIS (AISStream) — free key at https://aisstream.io
#AETHER_AIS=1
#AETHER_AIS_API_KEY=

# NASA FIRMS active fire — free MAP_KEY at https://firms.modaps.eosdis.nasa.gov/api/
#AETHER_FIRMS=1
#AETHER_FIRMS_MAP_KEY=

# ── NOAA GLM lightning (optional dep: pip install "aether[lightning]") ─────────
# run.sh installs that extra when you pass --with-lightning. G19 = GOES-East.
#AETHER_GLM=1
#AETHER_GLM_SATELLITE=G19

# ── Persistence / history (SQLite; M4) ────────────────────────────────────────
#AETHER_PERSIST=1
#AETHER_DB_PATH=aether.db
#AETHER_RETENTION_DAYS=30

# ── Notifications (optional) ──────────────────────────────────────────────────
#AETHER_DISCORD_WEBHOOK_URL=
#AETHER_SMTP_HOST=
#AETHER_SMTP_PORT=587
#AETHER_SMTP_USERNAME=
#AETHER_SMTP_PASSWORD=
#AETHER_EMAIL_FROM=
#AETHER_EMAIL_TO=
